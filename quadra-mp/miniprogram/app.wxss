page {
  background: #fff7f5;
  color: #5f4b46;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 214, 214, 0.52), transparent 28%),
    radial-gradient(circle at top right, rgba(255, 228, 209, 0.7), transparent 26%),
    linear-gradient(180deg, #fffaf7 0%, #fff4f1 48%, #fff7f5 100%);
}

.hero-card,
.section-card,
.form-card,
.list-card,
.empty-card {
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(255, 214, 208, 0.65);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 44rpx rgba(226, 153, 149, 0.12);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #7a4d47;
}

.section-subtitle {
  margin-top: 10rpx;
  color: #9c7c76;
  line-height: 1.6;
}

.primary-button {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #ff8f8f 0%, #ffb38a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.secondary-button {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 174, 168, 0.55);
  background: rgba(255, 247, 245, 0.95);
  color: #d96f66;
  font-size: 28rpx;
}

.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  height: 68rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 189, 177, 0.6);
  background: rgba(255, 247, 245, 0.82);
  color: #c96d63;
  font-size: 26rpx;
}

.field-label {
  margin-bottom: 14rpx;
  color: #8d6761;
  font-size: 26rpx;
}

.field-input,
.field-textarea,
.field-picker {
  min-height: 88rpx;
  padding: 0 26rpx;
  border-radius: 22rpx;
  background: #fff8f6;
  border: 2rpx solid rgba(247, 202, 195, 0.75);
  color: #5f4b46;
  box-sizing: border-box;
}

.field-input {
  display: flex;
  align-items: center;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx 26rpx;
}

.field-picker {
  display: flex;
  align-items: center;
}

.card-tip {
  margin-top: 16rpx;
  color: #b08c85;
  font-size: 24rpx;
  line-height: 1.6;
}

.pill-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 233, 227, 0.95);
  color: #cf7368;
  font-size: 24rpx;
}
