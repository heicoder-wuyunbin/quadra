<scroll-view class="page-shell index-page" scroll-y>
  <view class="hero-card hero-section">
    <view class="hero-copy">
      <text class="hero-kicker">Quadra 心动小站</text>
      <text class="hero-title">{{nickname}}</text>
      <text class="hero-subtitle">{{subtitle}}</text>
      <view class="status-row">
        <view class="status-pill {{sessionReady ? 'status-on' : 'status-off'}}">
          {{sessionReady ? '已登录' : '待登录'}}
        </view>
        <view class="status-pill status-soft">用户域优先联调</view>
      </view>
    </view>
    <image class="hero-avatar" src="{{avatar}}" mode="cover"></image>
  </view>

  <view class="section-card guide-card">
    <text class="section-title">从哪里开始？</text>
    <text class="section-subtitle">先把后端已经具备的能力接进小程序，再逐步扩展社交、内容与推荐。</text>
    <view class="guide-list">
      <view
        class="guide-item"
        wx:for="{{quickActions}}"
        wx:key="title"
        data-url="{{item.url}}"
        data-type="{{item.type}}"
        bindtap="handleActionTap"
      >
        <view>
          <text class="guide-title">{{item.title}}</text>
          <text class="guide-desc">{{item.desc}}</text>
        </view>
        <text class="guide-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section-card highlight-card">
    <text class="section-title">本期落地重点</text>
    <view class="highlight-list">
      <view class="highlight-item" wx:for="{{planHighlights}}" wx:key="*this">
        <text class="highlight-dot"></text>
        <text class="highlight-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-card footer-card">
    <text class="section-title">当前联调建议</text>
    <text class="section-subtitle">先启动网关和用户服务，再从“登录 → 我的资料 → 黑名单 → 破冰问题”顺序验证。</text>
    <button class="primary-button footer-button" bindtap="handleActionTap" data-url="/pages/login/index" data-type="navigate">
      现在去登录
    </button>
  </view>
</scroll-view>
