.login-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.login-hero,
.login-form {
  padding: 34rpx 30rpx;
}

.login-kicker {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 235, 230, 0.95);
  color: #e17d74;
  font-size: 24rpx;
}

.login-title {
  display: block;
  margin-top: 20rpx;
  color: #744b46;
  font-size: 42rpx;
  font-weight: 700;
}

.login-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #9b7872;
  line-height: 1.7;
}

.field-group + .field-group {
  margin-top: 24rpx;
}

.submit-button {
  margin-top: 36rpx;
}
