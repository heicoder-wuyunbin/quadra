      "delete": {
        "tags": [
          "Social"
        ],
        "summary": "取消关注",
        "description": "取消关注指定用户",
        "operationId": "unfollow",
        "parameters": [
          {
            "name": "targetUserId",
            "in": "path",
            "description": "目标用户ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
