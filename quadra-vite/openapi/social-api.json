    "/api/v1/social/swipes": {
      "post": {
        "tags": [
          "Social"
        ],
        "summary": "滑动操作",
        "description": "对用户进行 LIKE/DISLIKE 操作",
        "operationId": "swipe",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SwipeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMatchResultDTO"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/social/follows": {
      "post": {
        "tags": [
          "Social"
        ],
        "summary": "关注用户",
