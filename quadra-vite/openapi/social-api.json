      "ResultPageResultFollowerDTO": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/PageResultFollowerDTO"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "requestId": {
            "type": "string"
          }
        }
