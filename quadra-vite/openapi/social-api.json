        ],
        "summary": "获取粉丝列表",
        "description": "分页查询当前用户的粉丝列表",
        "operationId": "getFollowers",
        "parameters": [
          {
            "name": "pageNo",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
